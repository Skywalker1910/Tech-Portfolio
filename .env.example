# ─── GitHub API ──────────────────────────────────────────────────────────────
# Optional: increases GitHub API rate limit from 60 to 5000 req/hr
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# ─── AWS ─────────────────────────────────────────────────────────────────────
# Required for LOCAL DEVELOPMENT only.
# On AWS Amplify (production), credentials are provided automatically via IAM role.
# Create an IAM user with DynamoDBFullAccess (or scoped policy) for local dev:
# https://console.aws.amazon.com/iam/

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB table name (must match the table you create in AWS console)
DYNAMODB_CONTACTS_TABLE=portfolio-contacts

# ─── Contact Admin ────────────────────────────────────────────────────────────
# Secret key to authenticate GET /api/contact requests (view submissions).
# Use any strong random string. Generate one with: openssl rand -hex 32
CONTACT_ADMIN_KEY=
